datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum Status {
  TODO
  IN_PROGRESS
  DONE
}

enum MembershipRole {
  ADMIN
  MEMBER
}

enum CalendarEventSource {
  MANUAL
  GOOGLE
}

model User {
  id                Int                 @id @default(autoincrement())
  email             String              @unique
  passwordHash      String
  createdAt         DateTime            @default(now())
  tasks             Task[]
  assignedTasks     Task[]              @relation("TaskAssignee")
  memberships       Membership[]
  workflows         Workflow[]
  aiLogs            AiLog[]
  meetings          Meeting[]
  documents         Document[]
  emailDrafts       EmailDraft[]
  calendarEvents    CalendarEvent[]
  productivityStats ProductivityMetric[]
}

model Task {
  id             Int      @id @default(autoincrement())
  userId         Int
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  assigneeId     Int?
  assignee       User?    @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  title          String
  description    String?
  dueDate        DateTime?
  priority       Priority @default(MEDIUM)
  status         Status   @default(TODO)
  aiGenerated    Boolean  @default(false)
  createdAt      DateTime @default(now())
}

model Workflow {
  id               Int     @id @default(autoincrement())
  userId           Int
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId   Int?
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  triggerType      String
  triggerCondition Json
  actionType       String
  actionConfig     Json
  isActive         Boolean @default(true)
}

model AiLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt    String
  response  String
  createdAt DateTime @default(now())
}

model Organization {
  id           Int           @id @default(autoincrement())
  name         String
  createdAt    DateTime      @default(now())
  memberships  Membership[]
  tasks        Task[]
  workflows    Workflow[]
  meetings     Meeting[]
  documents    Document[]
}

model Membership {
  id             Int             @id @default(autoincrement())
  userId         Int
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId Int
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           MembershipRole  @default(MEMBER)

  @@unique([userId, organizationId])
}

model Meeting {
  id             Int      @id @default(autoincrement())
  userId         Int
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  title          String
  rawTranscript  String   @db.Text
  summary        String?  @db.Text
  actionItems    Json?
  createdAt      DateTime @default(now())
}

model Document {
  id             Int      @id @default(autoincrement())
  userId         Int
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  fileName       String
  fileUrl        String
  extractedText  String   @db.Text
  summary        String?  @db.Text
  createdAt      DateTime @default(now())
}

model EmailDraft {
  id               Int      @id @default(autoincrement())
  userId           Int
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt           String   @db.Text
  generatedSubject String
  generatedBody    String   @db.Text
  createdAt        DateTime @default(now())
}

model CalendarEvent {
  id              Int                   @id @default(autoincrement())
  userId          Int
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  startTime       DateTime
  endTime         DateTime
  source          CalendarEventSource   @default(MANUAL)
  externalEventId String?
  createdAt       DateTime              @default(now())

  @@index([userId, startTime])
}

model ProductivityMetric {
  id                Int      @id @default(autoincrement())
  userId            Int
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date              DateTime @db.Date
  tasksCompleted    Int      @default(0)
  workflowsTriggered Int     @default(0)
  aiActionsUsed     Int      @default(0)

  @@unique([userId, date])
}
